# Toilet block (facility) for the stall example.
# OBJ space: +X forward, +Y up, +Z right. Origin at the footprint-base centre.
# The door faces +X: the generator splits the faces near the +X edge into the
# door-wall sprite so guests sort into the doorway.
mtllib materials.mtl

# Building shell (y = 0 .. 1.6), half-extent 1.4
v -1.4 0.0 -1.4
v  1.4 0.0 -1.4
v  1.4 0.0  1.4
v -1.4 0.0  1.4
v -1.4 1.6 -1.4
v  1.4 1.6 -1.4
v  1.4 1.6  1.4
v -1.4 1.6  1.4
# Door slab, slightly proud of the +X wall (y = 0 .. 1.2, z = -0.4 .. 0.4)
v  1.41 0.0 -0.4
v  1.41 0.0  0.4
v  1.41 1.2  0.4
v  1.41 1.2 -0.4

vn  0.0 -1.0  0.0
vn  0.0  1.0  0.0
vn  0.0  0.0 -1.0
vn  0.0  0.0  1.0
vn -1.0  0.0  0.0
vn  1.0  0.0  0.0

usemtl Brick

# Bottom
f 1//1 2//1 3//1
f 1//1 3//1 4//1
# -Z wall
f 1//3 5//3 6//3
f 1//3 6//3 2//3
# +Z wall
f 4//4 3//4 7//4
f 4//4 7//4 8//4
# -X wall (back)
f 1//5 4//5 8//5
f 1//5 8//5 5//5
# +X wall (door side)
f 2//6 6//6 7//6
f 2//6 7//6 3//6

usemtl RoofSlate

# Flat roof
f 5//2 8//2 7//2
f 5//2 7//2 6//2

usemtl DoorWood

# Door slab on the +X face
f 9//6 12//6 11//6
f 9//6 11//6 10//6
